# Backend API base URL (Railway deployment or http://localhost:4000 in dev)
VITE_API_URL=https://robinhoodtownbackend-production.up.railway.app	

# RobinHoodTown ERC-721 contract on Robinhood Chain
VITE_NFT_CONTRACT=0x57ef7f8822bEB57ce7EE145e8Ebe2252b89B2B6B

# Robinhood Chain RPC + explorer (Arbitrum Orbit L2, chainId 4663)
VITE_RPC_URL=https://rpc.mainnet.chain.robinhood.com
VITE_EXPLORER_URL=https://robinhoodchain.blockscout.com

# Optional external links
VITE_TRADE_URL=#

# $RHT token contract address (CA) — leave empty until the Pons launch.
# While unset the topbar shows "CA: Launch soon on Pons!"; once set it
# shows the truncated address with click-to-copy.
VITE_RHT_CA=
